# ── Database (Supabase Supavisor pooler) ──
# Transaction mode (port 6543) for the app
DATABASE_URL=postgresql+asyncpg://postgres.{ref}:{password}@aws-0-{region}.pooler.supabase.com:6543/postgres
# Session mode (port 5432) for Alembic migrations ONLY
DATABASE_URL_SYNC=postgresql://postgres.{ref}:{password}@aws-0-{region}.pooler.supabase.com:5432/postgres

# ── PayFast ──
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase
PAYFAST_SANDBOX=true
PAYFAST_RETURN_URL=https://www.elitetcg.co.za/order/success
PAYFAST_CANCEL_URL=https://www.elitetcg.co.za/cart
PAYFAST_NOTIFY_URL=https://cgpf.elitetcg.co.za/api/v1/checkout/payfast/notify

# ── PayFast Marketplace & Promotions ──
PAYFAST_MARKETPLACE_RETURN_URL=https://www.elitetcg.co.za/marketplace/payment/success
PAYFAST_MARKETPLACE_CANCEL_URL=https://www.elitetcg.co.za/marketplace/payment/cancel
PAYFAST_MARKETPLACE_NOTIFY_URL=https://cgpf.elitetcg.co.za/api/v1/marketplace/payfast/notify
PAYFAST_PROMO_NOTIFY_URL=https://cgpf.elitetcg.co.za/api/v1/promotions/notify

# ── Payflex (BNPL) ──
PAYFLEX_MODE=sandbox                    # sandbox | production
PAYFLEX_CLIENT_ID=your_client_id
PAYFLEX_CLIENT_SECRET=your_client_secret
PAYFLEX_REDIRECT_URL=https://www.elitetcg.co.za/checkout/payflex/return
PAYFLEX_CALLBACK_URL=https://cgpf.elitetcg.co.za/api/v1/payments/payflex/webhook
# Auto-resolved from PAYFLEX_MODE, but can be overridden:
# PAYFLEX_AUTH_URL=https://auth.sandbox.payflex.co.za/auth/merchant
# PAYFLEX_API_URL=https://api.sandbox.payflex.co.za
# PAYFLEX_AUDIENCE=https://auth-sandbox.payflex.co.za

# ── The Courier Guy ──
COURIER_GUY_API_KEY=your-api-key
COURIER_GUY_ACCOUNT_NUMBER=your-account-number
COURIER_GUY_WEBHOOK_SECRET=your-webhook-secret

# ── Supabase Auth ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── App ──
FRONTEND_URL=https://www.elitetcg.co.za
APP_ENV=production
ADMIN_API_KEY=generate-a-secret-key-shared-with-elitetcg-backend

# ── Seller pickup address (for Courier Guy collection) ──
SELLER_COMPANY_NAME=Elite TCG
SELLER_ADDRESS_LINE1=123 Your Street
SELLER_CITY=Vanderbijlpark
SELLER_PROVINCE=Gauteng
SELLER_POSTAL_CODE=1900
SELLER_PHONE=0821234567
SELLER_EMAIL=you@example.com

# ── ZeptoMail (transactional emails) ──
ZEPTOMAIL_API_KEY=your-zeptomail-send-mail-token
ZEPTOMAIL_FROM_EMAIL=admin@elitetcg.co.za
ZEPTOMAIL_FROM_NAME=Elite TCG

# ── Pokemon TCG API (card evaluation) ──
POKEMON_TCG_API_KEY=your-pokemontcg-io-api-key

# ── Google Cloud Vision (card scanning) ──
GOOGLE_CLOUD_VISION_API_KEY=your-vision-api-key

# ── Exchange rate fallback ──
USD_TO_ZAR=17.80
